# Vercel project environment variables
# Set these in the Vercel dashboard for the rabbithole-consulting project
# (team: rabbitholes-projects-2d4b7f9f). Do not commit real values.

# Newsletter (api/subscribe.js)
NOTION_API_KEY=
NOTION_NEWSLETTER_DB_ID=

# Lead capture (api/leads.js)
# SUPABASE_URL: https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: server-only key, found in Supabase project settings
#   -> API -> service_role. NEVER expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# New-lead notification email (api/leads.js)
# RESEND_API_KEY: Resend API key. Already provisioned for the audit-complete
#   flow; reused here. If unset, lead inserts still succeed but no email fires.
# NOTIFICATION_TO_EMAILS: comma-separated recipient list. Defaults to JRP.
#   Set this in Vercel to add Austin (e.g. "jrp@...,austin@...").
RESEND_API_KEY=
NOTIFICATION_TO_EMAILS=goodgameconsultingllc@gmail.com

# New-lead notification Telegram (api/leads.js, via @ClinicGTMbot)
# TELEGRAM_BOT_TOKEN: bot token for @ClinicGTMbot.
# TELEGRAM_LEADS_CHAT_ID: numeric chat id of JRP's private DM with the bot.
# Both must be set or the Telegram step is skipped. Failures never break
# the lead-insert response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_LEADS_CHAT_ID=

# PostHog analytics (api/leads.js, api/subscribe.js)
# POSTHOG_API_KEY: PostHog project API key (public, safe to expose).
# POSTHOG_HOST: PostHog ingest host. Default: https://us.i.posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
