{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/bh-demo",
      "destination": "/api/demo?v=bh-demo"
    },
    {
      "source": "/bh-demo/:path*",
      "destination": "/api/demo?v=bh-demo&path=:path*"
    },
    {
      "source": "/clinic-demo",
      "destination": "/api/demo?v=clinic-demo"
    },
    {
      "source": "/clinic-demo/:path*",
      "destination": "/api/demo?v=clinic-demo&path=:path*"
    },
    {
      "source": "/restaurants-demo",
      "destination": "/api/demo?v=restaurants-demo"
    },
    {
      "source": "/restaurants-demo/:path*",
      "destination": "/api/demo?v=restaurants-demo&path=:path*"
    },
    {
      "source": "/salon-demo",
      "destination": "/api/demo?v=salon-demo"
    },
    {
      "source": "/salon-demo/:path*",
      "destination": "/api/demo?v=salon-demo&path=:path*"
    },
    {
      "source": "/hvac-demo",
      "destination": "/api/demo?v=hvac-demo"
    },
    {
      "source": "/hvac-demo/:path*",
      "destination": "/api/demo?v=hvac-demo&path=:path*"
    },
    {
      "source": "/hvac-mdemo",
      "destination": "https://hvac-maestro.vercel.app"
    },
    {
      "source": "/hvac-mdemo/:path*",
      "destination": "https://hvac-maestro.vercel.app/:path*"
    },
    {
      "source": "/plumber-mdemo",
      "destination": "https://plumber-maestro.vercel.app"
    },
    {
      "source": "/plumber-mdemo/:path*",
      "destination": "https://plumber-maestro.vercel.app/:path*"
    },
    {
      "source": "/salon-mdemo",
      "destination": "https://salon-maestro-fawn.vercel.app"
    },
    {
      "source": "/salon-mdemo/:path*",
      "destination": "https://salon-maestro-fawn.vercel.app/:path*"
    },
    {
      "source": "/restaurants-mdemo",
      "destination": "https://restaurants-maestro.vercel.app"
    },
    {
      "source": "/restaurants-mdemo/:path*",
